# Optional: contracts to index (comma/space/semicolon separated)
# Format: chainID:contractAddress:blockNumber
CONTRACTS=42220:0x0000000000000000000000000000000000000000:0

# Optional: comma/space/semicolon-separated RPC endpoints (can be multiple chains)
# If omitted, endpoints are discovered automatically via chainlist.org.
RPCS=https://celo-json-rpc.stakely.io,https://forno.celo.org

# Optional: database path (inside container). Defaults to /data in Dockerfile.
DB_PATH=/data

# Optional: HTTP listen address. Defaults to 0.0.0.0
LISTEN_ADDR=0.0.0.0

# Optional: HTTP listen port. Defaults to 8080.
LISTEN_PORT=8080

# Optional: CORS allowed origins. Use * to allow all.
# Supports comma/space/semicolon separated values.
CORS_ALLOWED_ORIGINS=*

# Optional: polling interval. Defaults to 5s.
POLL_INTERVAL=5s

# Optional: batch size per filterLogs. Defaults to 50.
BATCH_SIZE=50

# Optional: batch size per verification/tail rescan. Defaults to BATCH_SIZE.
VERIFY_BATCH_SIZE=50

# Optional: confirmation depth before blocks are considered safe to verify. Defaults to 12.
CONFIRMATIONS=12

# Optional: depth of the verified tail window continuously rescanned. Defaults to VERIFY_BATCH_SIZE.
TAIL_RESCAN_DEPTH=50

# Optional: log level (debug, info, warn, error). Defaults to debug.
LOG_LEVEL=debug

# Optional: domain for TLS certificate generation (Traefik).
DOMAIN=onchain-census-indexer.localhost

# Optional: domain for the dev deployment. Must resolve to the same Traefik instance.
DEV_DOMAIN=dev.onchain-census-indexer.localhost

# Optional: contracts for the dev deployment. If empty, the dev service starts without seeded contracts.
DEV_CONTRACTS=

# Optional: RPC endpoints for the dev deployment. If empty, the dev service auto-discovers RPCs.
DEV_RPCS=

# Optional: HTTP listen address for the dev deployment. Defaults to 0.0.0.0.
DEV_LISTEN_ADDR=0.0.0.0

# Optional: HTTP listen port inside the dev container. Defaults to 8080.
DEV_LISTEN_PORT=8080

# Optional: CORS allowed origins for the dev deployment. Defaults to *.
DEV_CORS_ALLOWED_ORIGINS=*

# Optional: polling interval for the dev deployment. Defaults to 5s.
DEV_POLL_INTERVAL=5s

# Optional: contract sync interval for the dev deployment. Defaults to 1s.
DEV_CONTRACT_SYNC_INTERVAL=1s

# Optional: batch size per filterLogs for the dev deployment. Defaults to 50.
DEV_BATCH_SIZE=50

# Optional: batch size per verification/tail rescan for the dev deployment. Defaults to DEV_BATCH_SIZE when set to 0.
DEV_VERIFY_BATCH_SIZE=0

# Optional: confirmation depth for the dev deployment. Defaults to 12.
DEV_CONFIRMATIONS=12

# Optional: verified tail rescan depth for the dev deployment. Defaults to DEV_VERIFY_BATCH_SIZE when set to 0.
DEV_TAIL_RESCAN_DEPTH=0

# Optional: log level for the dev deployment. Defaults to debug.
DEV_LOG_LEVEL=debug

# Optional: email used by Let's Encrypt account registration (Traefik).
ACME_EMAIL=root@vocdoni.io

# Optional: image tag for Docker deployment.
TAG=latest

# Optional: restart policy for Docker container.
RESTART=unless-stopped

# Optional: Watchtower update interval in seconds.
WATCHTOWER_INTERVAL=300
